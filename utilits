#!/usr/bin/env bash
ROOT="$(dirname "$0")"
DB="$ROOT/../db/db.json"

show_report() {
    if [ -f "$DB" ]; then
        echo -e "\n--- ОТЧЕТ АНАЛИЗА ---"
        jq -r '. | "Модуль: \(.module)\nПеременные: \(.variables|length)\nФункции: \(.functions|length)\nВремя: \(.timestamp)"' "$DB"
        echo "Переменные: $(jq -r '.variables[]' "$DB")"
    else
        echo "База пуста. Сначала запустите Grabber."
    fi
}

while true; do
    echo -e "\n--- Magisk Dev Manager ---"
    echo "1. Run Emulator (MEMU)"
    echo "2. Run Grabber (Analyze)"
    echo "3. Run Packer (Zip)"
    echo "4. Show Report"
    echo "5. Exit"
    read -p "Выберите: " opt

    case $opt in
        1) bash "$ROOT/memu.sh" ;;
        2) bash "$ROOT/grabber.sh" ;;
        3) bash "$ROOT/packer.sh" ;;
        4) show_report ;;
        5) break ;;
        *) echo "Неверно." ;;
    esac
done

#!/usr/bin/env bash
# Сборщик архива
BUILD_DIR="$(dirname "$0")/../source_build"
DIST_DIR="$(dirname "$0")/../dist"
mkdir -p "$DIST_DIR"

if [ ! -f "$BUILD_DIR/module.prop" ]; then
    echo "Ошибка: module.prop не найден в $BUILD_DIR"
    exit 1
fi

NAME="module_$(date +%Y%m%d_%H%M).zip"
cd "$BUILD_DIR" && zip -r "$DIST_DIR/$NAME" . > /dev/null

echo "[Packer] Успешно собрано: $DIST_DIR/$NAME"


#!/usr/bin/env bash
# Анализатор скриптов модуля
SRC="$(dirname "$0")/../source_work"
DB="$(dirname "$0")/../db/db.json"
mkdir -p "$(dirname "$DB")"

echo "[Grabber] Анализ..."
# Собираем данные через grep и формируем JSON через jq
VARS=$(grep -rE '^[A-Za-z_][A-Za-z0-9_]*=' "$SRC" | cut -d: -f2 | sort -u | jq -R . | jq -s .)
FUNCS=$(grep -rE '^[A-Za-z_][A-Za-z0-9_]*\(\)' "$SRC" | cut -d: -f2 | sort -u | jq -R . | jq -s .)

jq -n --arg name "$(basename "$SRC")" \
      --argjson vars "$VARS" \
      --argjson funcs "$FUNCS" \
      '{module: $name, variables: $vars, functions: $funcs, timestamp: now}' > "$DB"

echo "[Grabber] Данные записаны в $DB"


#!/usr/bin/env bash
# Эмулятор среды Magisk
WORKDIR="$(dirname "$0")/.."
SRC="$WORKDIR/source_work"
SANDBOX="$WORKDIR/sandbox"

echo "[MEMU] Очистка и запуск эмуляции..."
rm -rf "$SANDBOX" && mkdir -p "$SANDBOX/system" "$SANDBOX/bin"

# Export переменных
export MODPATH="$SANDBOX"
export TMPDIR="$WORKDIR/tmp"
export BOOTMODE=true
export ARCH=arm64
export API=33

# Mocks
ui_print() { echo -e "\e[32m[Magisk]\e[0m $1"; }
set_perm() { echo -e "\e[33m[Perms]\e[0m $4 ($3)"; }
export -f ui_print set_perm

if [ -f "$SRC/customize.sh" ]; then
    bash "$SRC/customize.sh"
else
    echo "Ошибка: customize.sh не найден в $SRC"
fi


